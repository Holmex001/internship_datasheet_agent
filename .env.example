# ==========================================
# 1. 文档向量化模型配置
# ==========================================
# 硅基流动（SiliconFlow）平台链接
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# 填入你自己的硅基流动 API Key（名字不要动）
EMBEDDING_API_KEY=sk-xxxxxxxx你的API_KEYxxxxxxxx
# 指导书指定的模型
EMBEDDING_MODEL=BAAI/bge-m3

# ==========================================
# 2. 数据手册存放目录
# ==========================================

DATASHEET_DIR=elecfans/downloads

# ==========================================
# 3. 大语言模型配置
# ==========================================
BASE_URL=https://api.deepseek.com
API_KEY=你的DeepSeek_API_KEY
MODEL=deepseek-chat

# ==========================================
# 4. 爬虫网站 Cookie（由爬虫同学提供，定期更新）
# ==========================================
ELECFANS_COOKIE=你的电子发烧友网站Cookie值